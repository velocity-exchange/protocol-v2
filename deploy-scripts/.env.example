# Copy to `.env` or `.env.local` in this directory (both are gitignored by `/**/*..env`).
# Override whenever you rotate the devnet drift program id.

# Required: must match `programs/drift` non-mainnet `declare_id!` and `[programs.devnet]` in Anchor.toml
DRIFT_DEVNET_PROGRAM_ID=vELoC1audYbSYVRXn1vPaV8Axoa9oU6BYmNGZZBDZ1P

# Required for deploy-devnet.sh / write-buffer-devnet.sh: upgrade authority (buffer authority)
DRIFT_DEVNET_UPGRADE_KEYPAIR=/path/to/devnet-upgrade-authority.json

# Path to JSON keypair file whose pubkey equals DRIFT_DEVNET_PROGRAM_ID (initial deploy / deploy-from-buffer only)
# PROGRAM_KEYPAIR=/path/to/drift-program-devnet.json

# Optional: instead of DRIFT_DEVNET_UPGRADE_KEYPAIR you may use legacy layout:
# SOLANA_PATH=/home/you/.config/solana
# DEVNET_ADMIN=my-upgrade.json

# Optional: private RPC or literal cluster name for anchor (default devnet)
# ANCHOR_PROVIDER_CLUSTER=https://api.devnet.solana.com
