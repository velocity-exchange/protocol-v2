{
	"name": "@drift/admin-cli",
	"version": "0.1.0",
	"description": "Drift v2 admin CLI: cold/warm/hot tier operations with optional Squads V4 multisig proposing.",
	"private": true,
	"type": "commonjs",
	"bin": {
		"drift-admin": "./src/index.ts"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"lint": "eslint './src/**/*.ts' --quiet --format unix",
		"prettify": "prettier --check './src/**/*.ts'",
		"prettify:fix": "prettier --write './src/**/*.ts'"
	},
	"dependencies": {
		"@coral-xyz/anchor": "0.32.1",
		"@drift-labs/sdk": "file:../sdk",
		"@solana/web3.js": "1.73.2",
		"@sqds/multisig": "2.1.3",
		"commander": "12.1.0"
	},
	"devDependencies": {
		"@types/node": "^20",
		"typescript": "5.4.5"
	}
}
