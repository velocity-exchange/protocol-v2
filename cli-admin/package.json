{
	"name": "@drift-labs/admin-cli",
	"version": "0.1.0",
	"description": "Drift v2 admin CLI: rotate authority keys, pause markets, and route operations through a Squads V4 multisig.",
	"author": "drift-labs",
	"homepage": "https://www.drift.trade/",
	"repository": {
		"type": "git",
		"url": "git@github.com:drift-labs/protocol-v2.git",
		"directory": "cli-admin"
	},
	"license": "Apache-2.0",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"bin": {
		"drift-admin": "lib/index.js"
	},
	"files": [
		"lib"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"drift-labs",
		"drift",
		"admin",
		"cli",
		"squads"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"clean": "rm -rf lib",
		"build": "yarn clean && tsc -p tsconfig.json && chmod +x lib/index.js",
		"prepare-publish": "node scripts/prepare-publish.js",
		"restore-publish": "node scripts/restore-publish.js",
		"publish-cli": "yarn build && yarn prepare-publish && (npm publish --access=public; status=$?; yarn restore-publish; exit $status)",
		"lint": "eslint './src/**/*.ts' --quiet --format unix",
		"prettify": "prettier --check './src/**/*.ts'",
		"prettify:fix": "prettier --write './src/**/*.ts'",
		"version": "node ./scripts/updateVersion.js"
	},
	"dependencies": {
		"@coral-xyz/anchor": "0.32.1",
		"@drift-labs/sdk": "file:../sdk",
		"@solana/web3.js": "1.73.2",
		"@sqds/multisig": "2.1.3",
		"commander": "12.1.0"
	},
	"devDependencies": {
		"@types/node": "^20",
		"typescript": "5.4.5"
	}
}
